<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jon's Fire: FB5X Foam Training Simulator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .glass-panel {
            background: rgba(30, 41, 59, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .btn-primary {
            background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
            transition: transform 0.1s, box-shadow 0.1s;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
        }
        .btn-primary:active {
            transform: translateY(0);
        }
        .btn-secondary {
            background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
            transition: transform 0.1s, box-shadow 0.1s;
        }
        .btn-secondary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
        }
        
        #canvas-container {
            position: relative;
            width: 100%;
            max-width: 800px;
            margin: 0 auto;
            border-radius: 0.5rem;
            overflow: hidden;
            background: #0f172a;
            border: 2px solid #334155;
        }
        canvas {
            display: block;
            width: 100%;
            height: auto;
        }
        
        /* Animations */
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fadeIn 0.4s ease-out forwards; }
    </style>
</head>
<body class="bg-slate-900 text-slate-100 min-h-screen flex flex-col items-center p-4 sm:p-8">

    <!-- Header -->
    <header class="w-full max-w-4xl flex justify-between items-center mb-8 border-b border-slate-700 pb-4">
        <div>
            <h1 class="text-3xl font-bold text-red-500 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c1.5 2 3 5.5 3 8s-1.5 4.5-3 4.5-3-2-3-4.5 3-6 3-8z"/><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-5.5c-.5 1.5-2 4-4 5.5S5 13 5 15a7 7 0 0 0 7 7z"/></svg>
                Jon's Fire Academy
            </h1>
            <p class="text-slate-400 text-sm">FB5X & Foam Application Theory</p>
        </div>
        <div id="score-display" class="hidden text-xl font-bold text-blue-400 bg-slate-800 px-4 py-2 rounded-lg border border-slate-700">
            Score: <span id="current-score">0</span>
        </div>
    </header>

    <!-- Main Content Area -->
    <main id="app-container" class="w-full max-w-4xl flex-grow flex flex-col gap-6">
        <!-- Views will be injected here by JS -->
    </main>

    <footer class="mt-12 text-slate-500 text-sm pb-4 text-center">
        <p>Operational training tool. Ensure environmental safety (minimise runoff) during live drills.</p>
    </footer>

    <script>
        // --- DATA & STATE ---
        const state = {
            view: 'menu', 
            score: 0,
            currentQuestionIndex: 0,
            activeTechnique: 'none',
            walker: { active: false, x: 250 },
            pressure: 5.5,
            mix: 3
        };

        // UI Handlers for Pressure and Mix
        function updateParams() {
            state.pressure = parseFloat(document.getElementById('pressure-slider').value);
            document.getElementById('pressure-val').innerText = state.pressure.toFixed(1);
            
            const desc = document.getElementById('pressure-desc');
            if (desc) {
                if (state.pressure < 4.5) {
                    desc.innerHTML = "<span class='text-orange-400'>Low Pressure:</span> Results in poor throw distance and soupy, unexpanded foam.";
                } else if (state.pressure > 7.5) {
                    desc.innerHTML = "<span class='text-red-400'>High Pressure:</span> Creates chaotic splash, blows the foam blanket apart, and wastes concentrate.";
                } else {
                    desc.innerHTML = "<span class='text-green-400'>Optimum Pressure:</span> Produces ideal foam expansion, structure, and throw distance.";
                }
            }
        }

        function setMix(val) {
            state.mix = val;
            document.getElementById('btn-mix-3').className = val === 3 ? 'flex-1 text-sm py-1.5 rounded-md bg-blue-600 text-white font-bold transition-all shadow-lg' : 'flex-1 text-sm py-1.5 rounded-md text-slate-400 hover:text-white font-bold transition-all';
            document.getElementById('btn-mix-6').className = val === 6 ? 'flex-1 text-sm py-1.5 rounded-md bg-blue-600 text-white font-bold transition-all shadow-lg' : 'flex-1 text-sm py-1.5 rounded-md text-slate-400 hover:text-white font-bold transition-all';
        }

        // Zubi code easter egg 
        console.log("Jon's Fire System Init. Zubi: 0 (Happening)");

        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.getElementById(tabId).classList.remove('hidden');
            
            document.querySelectorAll('.tab-btn').forEach(el => {
                el.classList.remove('border-blue-500', 'text-blue-400');
                el.classList.add('border-transparent', 'text-slate-400');
            });
            const activeBtn = document.getElementById('btn-' + tabId);
            activeBtn.classList.remove('border-transparent', 'text-slate-400');
            activeBtn.classList.add('border-blue-500', 'text-blue-400');
        }

        const quizQuestions = [
            {
                q: "What four elements must be present to produce mechanical foam?",
                options: [
                    "Water, Heat, Fuel, Chemical Reaction",
                    "Foam concentrate, Water, Air, Mechanical agitation",
                    "Foam concentrate, Nitrogen, Pressure, Branch pipe",
                    "Dry powder, Water, Air, Heat"
                ],
                answer: 1,
                explanation: "All four elements—foam concentrate, water, air, and mechanical agitation—must be present and blended in correct ratios to produce foam bubbles."
            },
            {
                q: "What is the maximum allowable distance between the inline inductor and the FB5X branch?",
                options: ["15 metres", "30 metres", "60 metres", "100 metres"],
                answer: 2,
                explanation: "The quick-reference guide states the distance must not exceed 60m between the inline inductor and the branch."
            },
            {
                q: "Which application technique is best suited for dike fires or spills around overturned vehicles?",
                options: ["Roll-On Method", "Bank-Down Method", "Rain-Down Method", "Direct Injection"],
                answer: 1,
                explanation: "The Bank-Down Method directs foam onto an elevated object (like a wall or tank shell) and lets it run down onto the fuel surface."
            },
            {
                q: "According to the transcript, why is the handle designed a specific way on the FB5X?",
                options: [
                    "To make it lighter to carry",
                    "So you don't block the air vents, allowing the Venturi principle to work",
                    "To prevent the branch from overheating",
                    "To allow for a 64mm instantaneous coupling connection"
                ],
                answer: 1,
                explanation: "The handle is designed so you don't block the air vents. It utilizes the Venturi principle to entrain air into the water mixture."
            },
            {
                q: "What happens if you walk through an established foam blanket?",
                options: ["The foam multiplies due to agitation", "The vapor seal is broken, allowing flammable vapors to escape and reignite", "The water content drains faster", "Nothing, mechanical foam is structural"],
                answer: 1,
                explanation: "Walking through a foam blanket breaks the physical seal isolating the vapors, immediately creating a hazard for reignition."
            },
            {
                q: "What is the operating pressure range of the Chubb FB5X?",
                options: ["1 to 5 bar", "3 to 10.5 bar", "5.5 to 12 bar", "10 to 15 bar"],
                answer: 1,
                explanation: "The operating pressure range is 3 to 10.5 bar, with standard water requirement calculated at 230 l/min at 5.5 bar."
            }
        ];

        // --- VIEWS ---
        const views = {
            menu: `
                <div class="glass-panel p-8 rounded-2xl text-center animate-fade-in">
                    <h2 class="text-3xl font-bold mb-4">Select a Training Module</h2>
                    <p class="text-slate-300 mb-8 max-w-2xl mx-auto">Master the theory and practical application of the Chubb FB5X foam branch pipe in Jon's Fire Academy. Choose a module below to begin.</p>
                    
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <button onclick="navigate('specs')" class="bg-slate-800 hover:bg-slate-700 p-6 rounded-xl border border-slate-600 transition-all group">
                            <div class="text-blue-400 mb-4 flex justify-center group-hover:scale-110 transition-transform">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M8 13h2"/><path d="M8 17h2"/><path d="M14 13h2"/><path d="M14 17h2"/></svg>
                            </div>
                            <h3 class="text-xl font-bold mb-2">FB5X Specs</h3>
                            <p class="text-sm text-slate-400">Review the quick-reference guide and capabilities.</p>
                        </button>
                        
                        <button onclick="navigate('simulator')" class="bg-slate-800 hover:bg-slate-700 p-6 rounded-xl border border-slate-600 transition-all group">
                            <div class="text-orange-400 mb-4 flex justify-center group-hover:scale-110 transition-transform">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                            </div>
                            <h3 class="text-xl font-bold mb-2">Application Simulator</h3>
                            <p class="text-sm text-slate-400">Visualize proper techniques and critical hazards.</p>
                        </button>
                        
                        <button onclick="navigate('quiz')" class="bg-slate-800 hover:bg-slate-700 p-6 rounded-xl border border-slate-600 transition-all group">
                            <div class="text-green-400 mb-4 flex justify-center group-hover:scale-110 transition-transform">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                            </div>
                            <h3 class="text-xl font-bold mb-2">Knowledge Check</h3>
                            <p class="text-sm text-slate-400">Test your understanding of foam theory and equipment.</p>
                        </button>
                    </div>
                </div>
            `,
            specs: `
                <div class="animate-fade-in">
                    <button onclick="navigate('menu')" class="mb-4 text-blue-400 hover:text-blue-300 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg> Back to Menu
                    </button>
                    <div class="glass-panel rounded-2xl overflow-hidden">
                        <div class="bg-slate-800 p-6 border-b border-slate-700">
                            <h2 class="text-2xl font-bold">Chubb FB5X Knowledge Base</h2>
                            <p class="text-slate-400 text-sm mt-1">Technical specifications and operational guidelines.</p>
                        </div>
                        
                        <!-- Tabs -->
                        <div class="flex flex-wrap border-b border-slate-700 bg-slate-800/50 px-4">
                            <button id="btn-tab-specs" onclick="switchTab('tab-specs')" class="tab-btn px-4 py-3 border-b-2 border-blue-500 text-blue-400 font-semibold transition-colors text-sm">Specs & Optimums</button>
                            <button id="btn-tab-adv" onclick="switchTab('tab-adv')" class="tab-btn px-4 py-3 border-b-2 border-transparent text-slate-400 hover:text-slate-200 font-semibold transition-colors text-sm">Advantages</button>
                            <button id="btn-tab-lim" onclick="switchTab('tab-lim')" class="tab-btn px-4 py-3 border-b-2 border-transparent text-slate-400 hover:text-slate-200 font-semibold transition-colors text-sm">Limitations</button>
                            <button id="btn-tab-how" onclick="switchTab('tab-how')" class="tab-btn px-4 py-3 border-b-2 border-transparent text-slate-400 hover:text-slate-200 font-semibold transition-colors text-sm">How to Use</button>
                            <button id="btn-tab-when" onclick="switchTab('tab-when')" class="tab-btn px-4 py-3 border-b-2 border-transparent text-slate-400 hover:text-slate-200 font-semibold transition-colors text-sm">When to Use</button>
                        </div>

                        <div class="p-6">
                            <!-- Tab: Specs -->
                            <div id="tab-specs" class="tab-content block overflow-x-auto">
                                <table class="w-full text-left border-collapse">
                                    <tbody>
                                        <tr class="border-b border-slate-700"><th class="p-3 text-slate-300 w-1/3">Water Requirement</th><td class="p-3">230 l/min at 5.5 bar</td></tr>
                                        <tr class="border-b border-slate-700"><th class="p-3 text-slate-300">Optimum Pressure</th><td class="p-3 text-green-400 font-bold">5.5 bar <span class="text-slate-400 font-normal text-sm ml-2">(Operating range: 3 to 10.5 bar)</span></td></tr>
                                        <tr class="border-b border-slate-700"><th class="p-3 text-slate-300">Foam Output</th><td class="p-3">2270 l/min</td></tr>
                                        <tr class="border-b border-slate-700"><th class="p-3 text-slate-300">Calibration Options</th><td class="p-3">3% or 6% or premix</td></tr>
                                        <tr class="border-b border-slate-700"><th class="p-3 text-slate-300">Optimum Throw (Range)</th><td class="p-3 text-green-400 font-bold">21m to 24m <span class="text-slate-400 font-normal text-sm ml-2">(At 5.5 bar optimum)</span></td></tr>
                                        <tr class="border-b border-slate-700"><th class="p-3 text-slate-300">Max Inductor Distance</th><td class="p-3 text-red-400 font-semibold">Must not exceed 60m</td></tr>
                                        <tr><th class="p-3 text-slate-300">Weight & Material</th><td class="p-3">Light alloy, 2 kg</td></tr>
                                    </tbody>
                                </table>
                            </div>

                            <!-- Tab: Advantages -->
                            <div id="tab-adv" class="tab-content hidden text-slate-300 space-y-4">
                                <ul class="list-disc pl-5 space-y-2">
                                    <li><strong>Lightweight & Portable:</strong> At only 2kg, it is easily handled by a single firefighter.</li>
                                    <li><strong>Venturi Air Entrainment:</strong> Effectively creates mechanical foam by mixing air and foam solution right at the branch.</li>
                                    <li><strong>Vapor Suppression:</strong> Rapidly blankets unignited fuel spills, preventing ignition by sealing off flammable vapors.</li>
                                    <li><strong>Cooling & Separating:</strong> Water content cools the fuel, while the foam blanket physically separates flames from the fuel surface.</li>
                                </ul>
                            </div>

                            <!-- Tab: Limitations -->
                            <div id="tab-lim" class="tab-content hidden text-slate-300 space-y-4">
                                <ul class="list-disc pl-5 space-y-2">
                                    <li><strong class="text-red-400">Ineffective on Class C/D:</strong> Do NOT use on energized electrical equipment, combustible metals, or pressurized gases.</li>
                                    <li><strong class="text-orange-400">Three-Dimensional Fires:</strong> Ineffective on flowing, plunging, or 3D fires as a secure blanket cannot be established.</li>
                                    <li><strong class="text-orange-400">Hose Lay Limits:</strong> Fails to draw concentrate if the distance between the inline inductor and the branch exceeds 60m.</li>
                                    <li><strong class="text-orange-400">Pressure Sensitive:</strong> Poor foam quality (soupy) if pressure is too low (< 4.5 bar) and blanket destruction if too high.</li>
                                    <li><strong class="text-orange-400">Environmental Impact:</strong> Foam concentrates are highly toxic to aquatic life. Runoff must be strictly minimized.</li>
                                </ul>
                            </div>

                            <!-- Tab: How to Use -->
                            <div id="tab-how" class="tab-content hidden text-slate-300 space-y-4">
                                <div class="bg-blue-900/20 border border-blue-800 p-3 rounded-lg mb-2 mt-1">
                                    <h4 class="text-blue-400 font-bold text-sm mb-1 uppercase tracking-wider">Hose Layout Options</h4>
                                    <p class="text-sm font-semibold mb-2"><span class="text-blue-300">Option 1 (Inline Inductor):</span> Pump Discharge &rarr; Inline Inductor (at pump) &rarr; 70mm Hose (Max 60m) &rarr; FB5X Branch</p>
                                    <p class="text-sm font-semibold"><span class="text-blue-300">Option 2 (Branch Dip Tube):</span> Pump Discharge &rarr; 70mm Hose &rarr; FB5X Branch (w/ Dip Tube directly into Foam Drum)</p>
                                </div>
                                <ol class="list-decimal pl-5 space-y-3">
                                    <li><strong>Connecting Up & The Dip Tube:</strong> You can induce foam at the pump using an inline inductor, or use the FB5X's own pick-up (dip) tube to draw foam directly from a container carried to the branch.</li>
                                    <li><strong>Continuous Supply (Practical Tip):</strong> To prevent running out of foam and breaking the suction, <strong class="text-blue-400">cut the top off the foam drum/bucket</strong>. This allows a second firefighter to continuously decant (pour) fresh foam concentrate into the open container as it empties, ensuring a steady and consistent flow.</li>
                                    <li><strong>Hose Lay:</strong> Run standard <strong>70mm delivery hose</strong> to the FB5X branch. <strong class="text-red-400">Crucial:</strong> If using an inline inductor, this hose line must not exceed 60 metres, otherwise friction and back-pressure will stop the inductor from picking up foam.</li>
                                    <li><strong>Calibration:</strong> Set the inductor dial to match your specific foam concentrate (typically 3% or 6%).</li>
                                    <li><strong>Pumping:</strong> Supply water at the optimum pressure of <strong>5.5 bar</strong>.</li>
                                    <li><strong>Handling:</strong> Hold the branch using the designated black handle. Never hold the base, as this blocks the Venturi air entrainment vents.</li>
                                    <li><strong>Application Method:</strong> Choose the best technique based on the fire environment:
                                        <ul class="list-disc pl-5 mt-2 text-sm text-slate-400">
                                            <li><em>Roll-On:</em> Direct in front of the spill, let it roll over the surface.</li>
                                            <li><em>Bank-Down:</em> Direct at an elevated object (tank/wall) and let it flow down onto the spill.</li>
                                            <li><em>Rain-Down:</em> Fan high into the air (deflecting with a gloved hand) to let foam gently fall onto the spill.</li>
                                        </ul>
                                    </li>
                                </ol>
                            </div>

                            <!-- Tab: When to Use -->
                            <div id="tab-when" class="tab-content hidden text-slate-300 space-y-4">
                                <ul class="list-disc pl-5 space-y-2">
                                    <li><strong>Unignited Spills:</strong> Securing vapor leaks from transport accidents, broken pipelines, or overfilled tanks to prevent ignition.</li>
                                    <li><strong>Class B Liquid Fires:</strong> Extinguishing ignited pools of petrol, diesel, oil, or specific polar solvents (if using AR-FFFP concentrate like Vapurex AR 3/3).</li>
                                    <li><strong>Target Locations:</strong> Commonly deployed at vehicle RTCs with fuel leaks, loading racks, small tank farms, and chemical plants.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            `,
            simulator: `
                <div class="animate-fade-in flex flex-col h-full">
                    <div class="flex justify-between items-center mb-4">
                        <button onclick="navigate('menu')" class="text-blue-400 hover:text-blue-300 flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg> Back to Menu
                        </button>
                        <button onclick="restartSimulator()" class="text-slate-400 hover:text-white flex items-center gap-2 px-3 py-1 rounded bg-slate-800 hover:bg-slate-700 transition-colors text-sm border border-slate-700">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg> Restart Fire
                        </button>
                    </div>
                    
                    <div class="glass-panel p-6 rounded-2xl mb-6">
                        <div class="flex flex-col md:flex-row justify-between gap-4 mb-4">
                            <!-- Standard Techniques -->
                            <div class="flex-1">
                                <h2 class="text-sm text-slate-400 uppercase tracking-wider font-bold mb-3">Application Techniques</h2>
                                <div class="flex flex-wrap gap-2">
                                    <button onclick="setTechnique('roll-on')" id="btn-roll-on" class="px-3 py-1.5 rounded-lg text-sm font-semibold bg-slate-700 hover:bg-slate-600 transition-colors">Roll-On</button>
                                    <button onclick="setTechnique('bank-down')" id="btn-bank-down" class="px-3 py-1.5 rounded-lg text-sm font-semibold bg-slate-700 hover:bg-slate-600 transition-colors">Bank-Down</button>
                                    <button onclick="setTechnique('rain-down')" id="btn-rain-down" class="px-3 py-1.5 rounded-lg text-sm font-semibold bg-slate-700 hover:bg-slate-600 transition-colors">Rain-Down</button>
                                </div>
                            </div>
                            <!-- Hazards & Scenarios -->
                            <div class="flex-1">
                                <h2 class="text-sm text-slate-400 uppercase tracking-wider font-bold mb-3">Hazards & Scenarios</h2>
                                <div class="flex flex-wrap gap-2">
                                    <button onclick="setTechnique('water-stream')" id="btn-water-stream" class="px-3 py-1.5 rounded-lg text-sm font-semibold bg-blue-900/40 hover:bg-blue-800 transition-colors border border-blue-700">Add Water</button>
                                    <button onclick="triggerWalkThrough()" id="btn-walk" class="px-3 py-1.5 rounded-lg text-sm font-semibold bg-orange-900/40 hover:bg-orange-800 transition-colors border border-orange-700">Walk Through</button>
                                    <button onclick="setTechnique('dry-powder')" id="btn-dry-powder" class="px-3 py-1.5 rounded-lg text-sm font-semibold bg-yellow-900/40 hover:bg-yellow-800 transition-colors border border-yellow-700">Dry Powder</button>
                                    <button onclick="setTechnique('basement-fill')" id="btn-basement-fill" class="px-3 py-1.5 rounded-lg text-sm font-semibold bg-purple-900/40 hover:bg-purple-800 transition-colors border border-purple-700">Basement Fill</button>
                                </div>
                            </div>
                        </div>
                        <div id="technique-desc" class="text-sm text-slate-300 h-20 sm:h-16 bg-slate-800/50 p-3 rounded border border-slate-700 flex items-center">
                            Select a technique or scenario above to see the visual demonstration.
                        </div>

                        <!-- NEW: Physics Controls -->
                        <div class="flex flex-col md:flex-row gap-4 mt-4 bg-slate-800/50 p-4 rounded-xl border border-slate-700">
                            <div class="flex-1">
                                <label class="text-xs text-slate-400 font-bold uppercase flex justify-between mb-2">
                                    <span>Pump Pressure</span>
                                    <span class="text-blue-400"><span id="pressure-val">5.5</span> Bar</span>
                                </label>
                                <input type="range" id="pressure-slider" min="3" max="10.5" step="0.5" value="5.5" class="w-full accent-blue-500" oninput="updateParams()">
                                <div class="flex justify-between text-[10px] text-slate-500 mt-1 font-semibold">
                                    <span>3.0</span>
                                    <span class="text-green-500 text-center">5.5<br>(Optimum)</span>
                                    <span>10.5</span>
                                </div>
                                <p id="pressure-desc" class="text-[10px] text-slate-400 mt-2 text-center h-6"><span class='text-green-400'>Optimum Pressure:</span> Produces ideal foam expansion, structure, and throw distance.</p>
                            </div>
                            <div class="flex-1">
                                <label class="text-xs text-slate-400 font-bold uppercase block mb-2">Concentrate Mix (%)</label>
                                <div class="flex bg-slate-900 rounded-lg p-1 border border-slate-700">
                                    <button id="btn-mix-3" onclick="setMix(3)" class="flex-1 text-sm py-1.5 rounded-md bg-blue-600 text-white font-bold transition-all shadow-lg">3%</button>
                                    <button id="btn-mix-6" onclick="setMix(6)" class="flex-1 text-sm py-1.5 rounded-md text-slate-400 hover:text-white font-bold transition-all">6%</button>
                                </div>
                                <p class="text-[10px] text-slate-400 mt-2 text-center">6% mix provides a slightly thicker, more stable foam blanket.</p>
                            </div>
                        </div>
                    </div>

                    <div id="canvas-container" class="shadow-2xl">
                        <canvas id="simCanvas" width="800" height="400"></canvas>
                        <div class="absolute top-2 right-2 bg-black/50 px-2 py-1 rounded text-xs text-slate-300 pointer-events-none">Jon's Fire Interactive Engine</div>
                    </div>
                </div>
            `,
            quiz: `
                <div class="animate-fade-in max-w-2xl mx-auto w-full">
                    <div class="flex justify-between items-center mb-6">
                        <button onclick="navigate('menu')" class="text-blue-400 hover:text-blue-300 flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg> Exit Quiz
                        </button>
                        <div class="text-sm font-bold text-slate-400">Question <span id="q-current">1</span> of <span id="q-total">X</span></div>
                    </div>
                    
                    <div class="glass-panel p-6 sm:p-8 rounded-2xl relative overflow-hidden">
                        <!-- Progress bar -->
                        <div class="absolute top-0 left-0 h-1 bg-slate-700 w-full">
                            <div id="quiz-progress" class="h-full bg-blue-500 transition-all duration-300" style="width: 0%"></div>
                        </div>

                        <h3 id="question-text" class="text-xl sm:text-2xl font-bold mb-6 mt-2">Question goes here?</h3>
                        
                        <div id="options-container" class="flex flex-col gap-3 mb-6">
                            <!-- Options injected here -->
                        </div>

                        <div id="feedback-container" class="hidden mb-6 p-4 rounded-lg text-sm border">
                            <!-- Feedback injected here -->
                        </div>

                        <button id="next-btn" onclick="nextQuestion()" class="hidden w-full btn-primary text-white font-bold py-3 px-4 rounded-lg">
                            Next Question
                        </button>
                    </div>
                </div>
            `,
            results: `
                <div class="animate-fade-in glass-panel p-8 rounded-2xl text-center max-w-lg mx-auto w-full">
                    <div class="mb-6 flex justify-center">
                        <div class="w-24 h-24 rounded-full bg-slate-800 flex items-center justify-center border-4 border-blue-500">
                            <span id="final-score" class="text-3xl font-bold text-white">0/0</span>
                        </div>
                    </div>
                    <h2 class="text-2xl font-bold mb-2" id="results-title">Training Complete!</h2>
                    <p class="text-slate-300 mb-8" id="results-message">Great job reviewing the FB5X materials.</p>
                    
                    <button onclick="navigate('menu')" class="btn-secondary w-full text-white font-bold py-3 px-4 rounded-lg flex items-center justify-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                        Return to Dashboard
                    </button>
                </div>
            `
        };

        // --- CORE LOGIC ---
        const appContainer = document.getElementById('app-container');
        const scoreDisplay = document.getElementById('score-display');
        const currentScoreEl = document.getElementById('current-score');

        function navigate(targetView) {
            state.view = targetView;
            
            stopSimulator();
            appContainer.innerHTML = views[targetView];

            if (targetView === 'quiz') {
                state.score = 0;
                state.currentQuestionIndex = 0;
                currentScoreEl.innerText = state.score;
                scoreDisplay.classList.remove('hidden');
                document.getElementById('q-total').innerText = quizQuestions.length;
                renderQuestion();
            } else if (targetView === 'simulator') {
                scoreDisplay.classList.add('hidden');
                initSimulator();
                setTechnique('roll-on'); 
            } else if (targetView === 'results') {
                scoreDisplay.classList.add('hidden');
                document.getElementById('final-score').innerText = `${state.score}/${quizQuestions.length}`;
                const percentage = state.score / quizQuestions.length;
                let title = "Needs Review";
                let msg = "Review the presentation materials and try again.";
                if (percentage === 1) { title = "Perfect Score!"; msg = "Excellent grasp of DWFRS foam theory and FB5X operation."; }
                else if (percentage >= 0.7) { title = "Solid Work"; msg = "Good understanding of the core concepts."; }
                document.getElementById('results-title').innerText = title;
                document.getElementById('results-message').innerText = msg;
            } else {
                scoreDisplay.classList.add('hidden');
            }
        }

        // --- QUIZ LOGIC ---
        function renderQuestion() {
            const q = quizQuestions[state.currentQuestionIndex];
            document.getElementById('q-current').innerText = state.currentQuestionIndex + 1;
            document.getElementById('question-text').innerText = q.q;
            
            const progress = ((state.currentQuestionIndex) / quizQuestions.length) * 100;
            document.getElementById('quiz-progress').style.width = `${progress}%`;

            const optsContainer = document.getElementById('options-container');
            optsContainer.innerHTML = '';
            
            q.options.forEach((opt, index) => {
                const btn = document.createElement('button');
                btn.className = "text-left w-full p-4 rounded-lg border border-slate-600 bg-slate-800 hover:bg-slate-700 transition-colors";
                btn.innerText = opt;
                btn.onclick = () => handleAnswer(index, btn);
                optsContainer.appendChild(btn);
            });

            document.getElementById('feedback-container').classList.add('hidden');
            document.getElementById('next-btn').classList.add('hidden');
        }

        function handleAnswer(selectedIndex, btnElement) {
            const q = quizQuestions[state.currentQuestionIndex];
            const optsContainer = document.getElementById('options-container');
            const buttons = optsContainer.querySelectorAll('button');
            
            buttons.forEach(b => b.disabled = true);
            const isCorrect = selectedIndex === q.answer;
            
            if (isCorrect) {
                state.score++;
                currentScoreEl.innerText = state.score;
                btnElement.classList.replace('bg-slate-800', 'bg-green-900');
                btnElement.classList.replace('border-slate-600', 'border-green-500');
            } else {
                btnElement.classList.replace('bg-slate-800', 'bg-red-900');
                btnElement.classList.replace('border-slate-600', 'border-red-500');
                buttons[q.answer].classList.replace('bg-slate-800', 'bg-green-900');
                buttons[q.answer].classList.replace('border-slate-600', 'border-green-500');
            }

            const feedback = document.getElementById('feedback-container');
            feedback.innerHTML = `<p class="font-bold mb-1 ${isCorrect ? 'text-green-400' : 'text-red-400'}">${isCorrect ? 'Correct!' : 'Incorrect.'}</p><p class="text-slate-300">${q.explanation}</p>`;
            feedback.classList.remove('hidden');
            feedback.classList.add(isCorrect ? 'bg-green-900/20' : 'bg-red-900/20', isCorrect ? 'border-green-800' : 'border-red-800');

            document.getElementById('next-btn').classList.remove('hidden');
            
            if (state.currentQuestionIndex === quizQuestions.length - 1) {
                document.getElementById('next-btn').innerText = "View Results";
            }
        }

        function nextQuestion() {
            state.currentQuestionIndex++;
            if (state.currentQuestionIndex < quizQuestions.length) renderQuestion();
            else navigate('results');
        }

        // --- SIMULATOR (CANVAS) LOGIC ---
        let simCanvas, ctx, simAnimationId;
        let particles = [];
        let foamBlanket = []; // Foam accumulation map
        let powderLevel = []; // Dry powder accumulation map

        const techDescriptions = {
            'roll-on': "<strong>Roll-On Method:</strong> Direct the foam stream on the ground near the front edge of a burning liquid spill, allowing foam to roll across the fuel surface.",
            'bank-down': "<strong>Bank-Down Method:</strong> Direct stream onto an elevated object (wall/tank). Foam runs down onto the fuel. Ideal for dike fires or overturned vehicles.",
            'rain-down': "<strong>Rain-Down Method:</strong> Spray foam into the air to fall onto the spill. Placing a gloved hand over the branch helps deflect and fan the foam evenly over the fire.",
            'water-stream': "<strong class='text-blue-400'>Add Water (Hazard):</strong> Water sinks beneath Class B fuels and boils to steam, causing violent splashing that rapidly destroys foam and spreads the fire.",
            'dry-powder': "<strong class='text-yellow-400'>Dry Powder (Hazard/Scenario):</strong> Dry powder provides rapid flame knockdown but creates NO vapor securing blanket. Its chemical makeup actively destroys existing foam blankets. Once application stops, fuel will rapidly reignite.",
            'basement-fill': "<strong class='text-purple-400'>Basement Fill (High/Med Exp):</strong> High Expansion foam flows like a fluid. It is pumped in to completely fill the volume, easily spreading across the floor, excluding oxygen and pushing out smoke."
        };

        function initSimulator() {
            simCanvas = document.getElementById('simCanvas');
            ctx = simCanvas.getContext('2d');
            particles = [];
            foamBlanket = [];
            powderLevel = [];
            state.walker.active = false;
            for(let i=0; i<80; i++) {
                foamBlanket.push(0);
                powderLevel.push(0);
            }
            simLoop();
        }

        function stopSimulator() {
            if (simAnimationId) cancelAnimationFrame(simAnimationId);
        }

        function restartSimulator() {
            particles = [];
            foamBlanket = foamBlanket.map(() => 0);
            powderLevel = powderLevel.map(() => 0);
            state.walker.active = false;
        }

        function triggerWalkThrough() {
            state.walker.active = true;
            state.walker.x = 250;
            document.getElementById('technique-desc').innerHTML = "<strong class='text-orange-400'>Walking Through (Hazard):</strong> Walking through an established foam blanket mechanically breaks the vapor seal. Flammable vapors immediately escape through the footprints and reignite.";
            
            ['roll-on', 'bank-down', 'rain-down', 'water-stream', 'basement-fill', 'dry-powder'].forEach(t => {
                const btn = document.getElementById(`btn-${t}`);
                if(btn) btn.classList.remove('bg-blue-600', 'bg-blue-800', 'bg-purple-600', 'bg-yellow-600', 'text-white');
            });
            state.activeTechnique = 'none'; 
        }

        function setTechnique(tech) {
            state.activeTechnique = tech;
            state.walker.active = false;
            document.getElementById('technique-desc').innerHTML = techDescriptions[tech] || "";
            
            ['roll-on', 'bank-down', 'rain-down'].forEach(t => {
                const btn = document.getElementById(`btn-${t}`);
                if(btn) { btn.classList.remove('bg-blue-600', 'text-white'); btn.classList.add('bg-slate-700'); }
            });
            ['water-stream', 'basement-fill', 'dry-powder'].forEach(t => {
                const btn = document.getElementById(`btn-${t}`);
                if(btn) {
                    if(t === 'water-stream') btn.classList.remove('bg-blue-600', 'text-white');
                    if(t === 'basement-fill') btn.classList.remove('bg-purple-600', 'text-white');
                    if(t === 'dry-powder') btn.classList.remove('bg-yellow-600', 'text-white');
                }
            });

            const activeBtn = document.getElementById(`btn-${tech}`);
            if(activeBtn) {
                if (tech === 'water-stream') activeBtn.classList.add('bg-blue-600', 'text-white');
                else if (tech === 'basement-fill') activeBtn.classList.add('bg-purple-600', 'text-white');
                else if (tech === 'dry-powder') activeBtn.classList.add('bg-yellow-600', 'text-white');
                else {
                    activeBtn.classList.remove('bg-slate-700');
                    activeBtn.classList.add('bg-blue-600', 'text-white');
                }
            }

            // Clear previous layers when completely switching environment types
            if (tech === 'basement-fill' || tech === 'roll-on' || tech === 'bank-down' || tech === 'rain-down') {
                particles = [];
                foamBlanket = foamBlanket.map(() => 0);
                powderLevel = powderLevel.map(() => 0);
            }
        }

        class Particle {
            constructor(x, y, vx, vy, type) {
                this.x = x;
                this.y = y;
                this.vx = vx + (Math.random() - 0.5) * 1.5; 
                this.vy = vy + (Math.random() - 0.5) * 1.5;
                this.life = 1.0;
                this.type = type; 
                this.size = Math.random() * 4 + 3;
            }
            update() {
                this.x += this.vx;
                this.y += this.vy;
                this.life -= 0.005;

                // Unique Physics based on technique
                if (this.type === 'roll-on') {
                    this.vy += 0.2; 
                    if (this.y > 340) { 
                        this.y = 340; this.vy = 0; this.vx = 4; 
                    }
                } else if (this.type === 'bank-down') {
                    this.vy += 0.1; 
                    if (this.x > 650 && this.y < 340) { 
                        this.x = 650; this.vx = 0; this.vy = 3; 
                    }
                    if (this.y > 340) { 
                        this.y = 340; this.vy = 0; this.vx = -1.5; 
                    }
                } else if (this.type === 'rain-down') {
                    this.vy += 0.15; 
                    if (this.y > 340) { 
                        this.y = 340; this.vx = 0; this.vy = 0;
                    }
                } else if (this.type === 'water-stream') {
                    this.vy += 0.2; // Gravity
                    if (this.y > 340) { 
                        this.y = 340; this.vx = 0; this.vy = 0; this.life -= 0.05; 
                    }
                } else if (this.type === 'dry-powder') {
                    this.vx *= 0.95; // High air resistance creates floating cloud
                    this.vy += 0.05; // Settles slowly
                    this.size += 0.1; // Expands over time
                } else if (this.type === 'basement-fill') {
                    this.vy += 0.08; // Very light
                    this.vx *= 0.98; // Air resistance spreads it
                }

                // Grid Interaction
                let segment = Math.floor(this.x / 10);
                
                // Add foam logic for standard techniques
                if ((this.type === 'roll-on' || this.type === 'bank-down' || this.type === 'rain-down') && this.y >= 340 && Math.abs(this.vx) < 5) {
                    if (segment >= 0 && segment < 80) {
                        if (foamBlanket[segment] < 20) { 
                            // Pressure affects foam quality
                            let quality = 1.0;
                            if (state.pressure < 4.5) quality = 0.4; // Soupy
                            else if (state.pressure > 7.5) quality = 0.5; // Blown apart
                            
                            // Mix affects blanket thickness
                            let mixMultiplier = state.mix === 6 ? 1.4 : 1.0;
                            
                            foamBlanket[segment] += (0.2 * quality * mixMultiplier);
                            this.life -= 0.05; 
                        }
                    }
                }

                // Destroy foam logic for water stream and dry powder (aggressively clears blanket)
                if ((this.type === 'water-stream' && this.y >= 340) || (this.type === 'dry-powder' && this.y >= 300)) {
                    if (segment >= 0 && segment < 80) {
                        if (foamBlanket[segment] > 0) {
                            let destroyRate = this.type === 'water-stream' ? 1.0 : 0.8;
                            foamBlanket[segment] -= destroyRate; 
                            if (foamBlanket[segment] < 0) foamBlanket[segment] = 0;
                        }
                        
                        // Hitting bare fuel with water causes massive violent splashing/flare up!
                        if (this.type === 'water-stream' && foamBlanket[segment] === 0) {
                             powderLevel[segment] = -8; // Negative powder represents boiling fuel splash flare
                        }
                    }
                }

                // Add to Powder level (does not add to secure foam blanket)
                if (this.type === 'dry-powder' && this.y > 280) {
                    if (segment >= 0 && segment < 80) {
                        powderLevel[segment] = Math.min(powderLevel[segment] + 1.0, 15);
                    }
                }

                // Fast feeding for Basement Fill (spread handled by cellular automata later)
                if (this.type === 'basement-fill') {
                    if (segment >= 25 && segment <= 75) { 
                        let floorY = 340 - foamBlanket[segment];
                        if (this.y >= floorY || this.x > 740) {
                            if (foamBlanket[segment] < 240) { 
                                foamBlanket[segment] += 2.5; 
                            }
                            this.life = 0; 
                        }
                    }
                }
            }
            draw(ctx) {
                if (this.type === 'water-stream') {
                    ctx.fillStyle = `rgba(59, 130, 246, ${this.life})`; // Blue water
                } else if (this.type === 'dry-powder') {
                    ctx.fillStyle = `rgba(253, 224, 71, ${this.life * 0.4})`; // Yellow/White dust
                } else {
                    ctx.fillStyle = `rgba(226, 232, 240, ${this.life})`; // White foam
                }
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        function simLoop() {
            ctx.clearRect(0, 0, simCanvas.width, simCanvas.height);

            // 1. Environmental Decay/Fluid Dynamics
            
            // Powder decays very rapidly when spray stops. Negative powder (water splash flare) recovers back to 0.
            for(let i=0; i<80; i++) {
                if(powderLevel[i] > 0) powderLevel[i] -= 0.15; 
                else if(powderLevel[i] < 0) powderLevel[i] += 0.2; // Recover from flare
                
                if(Math.abs(powderLevel[i]) < 0.2) powderLevel[i] = 0;
            }

            // Universal Foam fluid dynamics (cellular automata spreading)
            let newFoam = [...foamBlanket];
            for (let i = 25; i <= 75; i++) {
                if (foamBlanket[i] > 0) {
                    // Standard foam is thicker and stacks higher than high-expansion basement foam
                    let fluidity = (state.activeTechnique === 'basement-fill') ? 1.0 : 4.0;
                    let transfer = (state.activeTechnique === 'basement-fill') ? 0.45 : 0.2;

                    // Flow right
                    if (i < 75 && foamBlanket[i] > foamBlanket[i + 1] + fluidity) {
                        let diff = (foamBlanket[i] - foamBlanket[i + 1]) * transfer;
                        newFoam[i] -= diff; newFoam[i + 1] += diff;
                    }
                    // Flow left
                    if (i > 25 && foamBlanket[i] > foamBlanket[i - 1] + fluidity) {
                        let diff = (foamBlanket[i] - foamBlanket[i - 1]) * transfer;
                        newFoam[i] -= diff; newFoam[i - 1] += diff;
                    }
                }
            }
            foamBlanket = newFoam;

            // 2. Draw Environments
            ctx.fillStyle = '#1e293b'; 
            ctx.fillRect(0, 0, 800, 400);

            if (state.activeTechnique === 'basement-fill') {
                ctx.fillStyle = '#0f172a'; // Dark interior
                ctx.fillRect(250, 100, 500, 250);
                
                ctx.fillStyle = '#475569';
                ctx.fillRect(210, 80, 40, 70); // Window top
                ctx.fillRect(210, 200, 40, 150); // Window bottom
                ctx.fillRect(750, 80, 40, 270); // Back wall
                ctx.fillRect(210, 80, 580, 20); // Ceiling
            }

            // Draw Ground and Fuel Spill
            ctx.fillStyle = '#334155';
            ctx.fillRect(0, 350, 800, 50);
            ctx.fillStyle = '#991b1b'; 
            ctx.fillRect(250, 345, 500, 5);
            
            // 3. Draw Flames
            // Logic: Fire exists if foam < 10 AND powder < 5 (powder gives temporary knockdown)
            for(let i=25; i<75; i+=3) {
                if (foamBlanket[i] < 10 && powderLevel[i] < 5) {
                    let intensity = (foamBlanket[i] <= 0) ? 1.5 : 1.0; 
                    if (powderLevel[i] < 0) intensity = 3.5; // Massive flare from water splash
                    
                    ctx.fillStyle = `rgba(249, 115, 22, ${Math.random() * 0.5 + 0.5})`; 
                    let flameHeight = (Math.random() * 30 + 10 - (foamBlanket[i]*2)) * intensity;
                    
                    if (flameHeight > 0) {
                        ctx.beginPath();
                        ctx.moveTo(i*10, 345);
                        ctx.lineTo(i*10 + 5, 345 - flameHeight);
                        ctx.lineTo(i*10 + 10, 345);
                        ctx.fill();
                    }
                }
            }

            if (state.activeTechnique === 'bank-down') {
                ctx.fillStyle = '#475569';
                ctx.fillRect(660, 150, 40, 200);
            }

            // 4. Draw Firefighter/Branch
            let nozzleX = 50, nozzleY = 300;
            let emitVx = 0, emitVy = 0;

            if (state.activeTechnique === 'basement-fill') {
                ctx.fillStyle = '#facc15'; 
                ctx.fillRect(170, 150, 20, 80); 
                ctx.fillStyle = '#94a3b8'; 
                ctx.fillRect(180, 160, 50, 25); // MX/HX Generator
                
                emitVx = 6; emitVy = 2; 
                nozzleX = 230; nozzleY = 172;
            } else {
                ctx.fillStyle = '#facc15'; 
                ctx.fillRect(30, 270, 20, 80);
                ctx.fillStyle = '#94a3b8'; 
                
                if (state.activeTechnique === 'roll-on') {
                    ctx.fillRect(40, 300, 40, 8); 
                    emitVx = 8; emitVy = 2;
                    nozzleX = 80; nozzleY = 304;
                } else if (state.activeTechnique === 'water-stream') {
                    ctx.fillRect(40, 290, 40, 8); 
                    // Shoots significantly further (into the 300-600 fire zone)
                    emitVx = 15 + Math.random() * 3; 
                    emitVy = -1 + (Math.random() - 0.5) * 2;
                    nozzleX = 80; nozzleY = 294;
                } else if (state.activeTechnique === 'dry-powder') {
                    ctx.fillRect(40, 300, 40, 8); 
                    emitVx = 14; emitVy = -1.5;
                    nozzleX = 80; nozzleY = 304;
                } else if (state.activeTechnique === 'bank-down') {
                    ctx.fillRect(40, 290, 40, 8); 
                    emitVx = 12; emitVy = -3;
                    nozzleX = 80; nozzleY = 294;
                } else if (state.activeTechnique === 'rain-down') {
                    ctx.save();
                    ctx.translate(40, 300);
                    ctx.rotate(-Math.PI / 4); 
                    ctx.fillRect(0, 0, 40, 8); 
                    ctx.fillStyle = '#0f172a'; // Gloved hand
                    ctx.fillRect(35, -8, 10, 15);
                    ctx.restore();
                    
                    emitVx = 3.5 + (Math.random() * 2.5);
                    emitVy = -7.5 - (Math.random() * 1.5);
                    nozzleX = 65; nozzleY = 265;
                }
            }

            // Apply Pressure Physics to Throw Range
            if (state.activeTechnique !== 'none' && state.activeTechnique !== 'basement-fill') {
                let pRatio = state.pressure / 5.5; // 1.0 at optimum
                emitVx *= pRatio;
                // High pressure creates chaotic splash
                if (state.pressure > 7.5) {
                    emitVy += (Math.random() - 0.5) * (state.pressure - 6);
                }
            }

            // Emit Particles
            if (state.activeTechnique !== 'none' && Math.random() > 0.1) {
                let particleCount = (state.activeTechnique === 'basement-fill') ? 10 : 4;
                if(state.activeTechnique === 'dry-powder') particleCount = 6; // Thicker cloud
                
                for(let i=0; i<particleCount; i++) {
                    particles.push(new Particle(nozzleX, nozzleY, emitVx, emitVy, state.activeTechnique));
                }
            }

            // Update & Draw Particles
            for (let i = particles.length - 1; i >= 0; i--) {
                let p = particles[i];
                p.update();
                p.draw(ctx);
                if (p.life <= 0) particles.splice(i, 1);
            }

            // 5. Draw Hazards
            if (state.walker.active) {
                state.walker.x += 1.5; 
                let bounce = Math.abs(Math.sin(state.walker.x * 0.1)) * 6;
                
                ctx.fillStyle = '#451a03'; // Boots
                ctx.fillRect(state.walker.x - 8, 320 - bounce, 8, 20); 
                ctx.fillRect(state.walker.x + 2, 330 - (6-bounce), 8, 20); 
                ctx.fillRect(state.walker.x + 2, 350 - (6-bounce), 14, 6); 

                // Break the foam blanket at their feet
                let seg = Math.floor((state.walker.x + 5) / 10);
                if (seg >= 0 && seg < 80) {
                    foamBlanket[seg] = 0;
                    if (seg > 0) foamBlanket[seg-1] = 0;
                }
                if (state.walker.x > 750) state.walker.active = false; 
            }

            // 6. Draw physical foam blanket
            ctx.fillStyle = 'rgba(248, 250, 252, 0.9)'; 
            for(let i=0; i<80; i++) {
                if (foamBlanket[i] > 0) {
                    ctx.fillRect(i*10, 345 - foamBlanket[i], 12, foamBlanket[i] + 5);
                }
            }

            simAnimationId = requestAnimationFrame(simLoop);
        }

        // Init App
        navigate('menu');

    </script>
</body>
</html>










